NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (required — PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codevault

# JWT signing (generate strong random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Firebase Admin SDK (service account)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: Upstash Redis (sessions / refresh token store)
REDIS_URL=

# Optional: Gemini API Key for AI Coach (falls back to custom mock if empty)
GEMINI_API_KEY=
