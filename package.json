{
  "name": "codevault",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:api": "pnpm --filter @codevault/api dev",
    "dev:web": "pnpm --filter @codevault/web dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @codevault/web build"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.15.0"
}
